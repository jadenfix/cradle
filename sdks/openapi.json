{
  "openapi": "3.1.0",
  "info": {
    "title": "beatbox API",
    "description": "HTTP and MCP server surfaces for beatbox.",
    "license": {
      "name": "Apache-2.0",
      "identifier": "Apache-2.0"
    },
    "version": "0.1.0"
  },
  "paths": {
    "/mcp": {
      "post": {
        "tags": [
          "mcp"
        ],
        "operationId": "mcp_post",
        "responses": {
          "200": {
            "description": "JSON-RPC response"
          },
          "202": {
            "description": "JSON-RPC notification accepted"
          },
          "403": {
            "description": "Origin not allowed"
          }
        }
      }
    },
    "/v1/capabilities": {
      "get": {
        "tags": [
          "v1"
        ],
        "operationId": "capabilities",
        "responses": {
          "200": {
            "description": "Lane availability and host limits"
          },
          "401": {
            "description": "Missing or invalid bearer token"
          }
        }
      }
    },
    "/v1/execute": {
      "post": {
        "tags": [
          "v1"
        ],
        "operationId": "execute",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExecuteRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "ExecutionResult",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecutionResult"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Protocol, source, policy, or sync-limit rejection",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/health": {
      "get": {
        "tags": [
          "v1"
        ],
        "operationId": "health",
        "responses": {
          "200": {
            "description": "Daemon health"
          }
        }
      }
    },
    "/v1/jobs": {
      "post": {
        "tags": [
          "v1"
        ],
        "operationId": "create_job",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExecuteRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Created asynchronous job",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateJobResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Idempotency key reused with a different payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Protocol, source, policy, or job-limit rejection",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Concurrency cap exhausted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/jobs/{id}": {
      "get": {
        "tags": [
          "v1"
        ],
        "operationId": "get_job",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Job id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "JobRecord",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobRecord"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Unknown job",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "v1"
        ],
        "operationId": "cancel_job",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Job id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Canceled job (or already canceled)"
          },
          "401": {
            "description": "Missing or invalid bearer token"
          },
          "404": {
            "description": "Unknown job"
          },
          "409": {
            "description": "Job already finished and cannot be canceled"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateJobResponse": {
        "type": "object",
        "required": [
          "job_id"
        ],
        "properties": {
          "job_id": {
            "type": "string"
          }
        }
      },
      "Determinism": {
        "oneOf": [
          {
            "type": "object",
            "required": [
              "kind"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "off"
                ]
              }
            }
          },
          {
            "type": "object",
            "required": [
              "seed",
              "epoch_ms",
              "kind"
            ],
            "properties": {
              "epoch_ms": {
                "type": "integer",
                "format": "int64",
                "minimum": 0
              },
              "kind": {
                "type": "string",
                "enum": [
                  "seeded"
                ]
              },
              "seed": {
                "type": "integer",
                "format": "int64",
                "minimum": 0
              }
            }
          }
        ]
      },
      "EffectiveIsolation": {
        "type": "object",
        "required": [
          "os",
          "mechanisms",
          "downgrades"
        ],
        "properties": {
          "downgrades": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "landlock_abi": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int32",
            "minimum": 0
          },
          "mechanisms": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "os": {
            "type": "string"
          }
        }
      },
      "EgressRecord": {
        "type": "object",
        "required": [
          "domain",
          "port",
          "bytes"
        ],
        "properties": {
          "bytes": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "domain": {
            "type": "string"
          },
          "port": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      },
      "ErrorBody": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ErrorBody"
          }
        }
      },
      "ExecuteRequest": {
        "type": "object",
        "required": [
          "lane",
          "source"
        ],
        "properties": {
          "entrypoint": {
            "type": [
              "string",
              "null"
            ]
          },
          "idempotency_key": {
            "type": [
              "string",
              "null"
            ]
          },
          "input": {},
          "lane": {
            "$ref": "#/components/schemas/Lane"
          },
          "policy": {
            "$ref": "#/components/schemas/Policy"
          },
          "source": {
            "$ref": "#/components/schemas/Source"
          },
          "stdin": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "ExecutionResult": {
        "type": "object",
        "required": [
          "status",
          "value",
          "stdout",
          "stdout_truncated",
          "stderr",
          "stderr_truncated",
          "metrics",
          "lane",
          "deterministic",
          "inputs_digest",
          "engine_version",
          "beatbox_version",
          "effective_isolation",
          "egress"
        ],
        "properties": {
          "beatbox_version": {
            "type": "string"
          },
          "deterministic": {
            "type": "boolean"
          },
          "effective_isolation": {
            "$ref": "#/components/schemas/EffectiveIsolation"
          },
          "egress": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EgressRecord"
            }
          },
          "engine_version": {
            "type": "string"
          },
          "error": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ErrorBody"
              }
            ]
          },
          "exit_code": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int32"
          },
          "inputs_digest": {
            "type": "string"
          },
          "lane": {
            "$ref": "#/components/schemas/Lane"
          },
          "metrics": {
            "$ref": "#/components/schemas/Metrics"
          },
          "status": {
            "$ref": "#/components/schemas/ExecutionStatus"
          },
          "stderr": {
            "type": "string"
          },
          "stderr_truncated": {
            "type": "boolean"
          },
          "stdout": {
            "type": "string"
          },
          "stdout_truncated": {
            "type": "boolean"
          },
          "value": {}
        }
      },
      "ExecutionStatus": {
        "type": "string",
        "enum": [
          "ok",
          "error",
          "timeout",
          "oom",
          "killed",
          "denied"
        ]
      },
      "FsPolicy": {
        "type": "object",
        "properties": {
          "mounts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Mount"
            }
          },
          "workspace": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      },
      "JobRecord": {
        "type": "object",
        "required": [
          "job_id",
          "status",
          "request",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "created_at": {
            "type": "string"
          },
          "error": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ErrorBody"
              }
            ]
          },
          "job_id": {
            "type": "string"
          },
          "request": {
            "$ref": "#/components/schemas/ExecuteRequest"
          },
          "result": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ExecutionResult"
              }
            ]
          },
          "status": {
            "$ref": "#/components/schemas/JobStatus"
          },
          "updated_at": {
            "type": "string"
          }
        }
      },
      "JobStatus": {
        "type": "string",
        "enum": [
          "queued",
          "running",
          "succeeded",
          "failed",
          "canceled"
        ]
      },
      "Lane": {
        "type": "string",
        "enum": [
          "wasm",
          "python_wasi",
          "python_native",
          "js_wasm",
          "js_native",
          "exec"
        ]
      },
      "Limits": {
        "type": "object",
        "properties": {
          "cpu_ms": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "disk_bytes": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "fuel": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "minimum": 0
          },
          "memory_bytes": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "output_bytes": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "pids": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "wall_ms": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          }
        },
        "additionalProperties": false
      },
      "Metrics": {
        "type": "object",
        "required": [
          "wall_time_ms"
        ],
        "properties": {
          "cpu_time_ms": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "description": "CPU time in milliseconds, when the lane measures it separately from wall\ntime. The W0 wasm lane does not, so this is `None` there — use `fuel_used`\nas the deterministic compute signal rather than treating wall time as CPU.",
            "minimum": 0
          },
          "fuel_used": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "minimum": 0
          },
          "peak_memory_bytes": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "minimum": 0
          },
          "wall_time_ms": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          }
        }
      },
      "Mount": {
        "type": "object",
        "required": [
          "host",
          "guest",
          "mode"
        ],
        "properties": {
          "guest": {
            "type": "string"
          },
          "host": {
            "type": "string"
          },
          "mode": {
            "$ref": "#/components/schemas/MountMode"
          }
        },
        "additionalProperties": false
      },
      "MountMode": {
        "type": "string",
        "enum": [
          "ro",
          "rw"
        ]
      },
      "NetPolicy": {
        "oneOf": [
          {
            "type": "object",
            "required": [
              "kind"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "deny"
                ]
              }
            }
          },
          {
            "type": "object",
            "required": [
              "kind"
            ],
            "properties": {
              "allow_domains": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "allow_ports": {
                "type": "array",
                "items": {
                  "type": "integer",
                  "format": "int32",
                  "minimum": 0
                }
              },
              "kind": {
                "type": "string",
                "enum": [
                  "proxy"
                ]
              }
            }
          }
        ]
      },
      "Policy": {
        "type": "object",
        "properties": {
          "determinism": {
            "$ref": "#/components/schemas/Determinism"
          },
          "double_jail": {
            "type": "boolean"
          },
          "env": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "propertyNames": {
              "type": "string"
            }
          },
          "fs": {
            "$ref": "#/components/schemas/FsPolicy"
          },
          "limits": {
            "$ref": "#/components/schemas/Limits"
          },
          "net": {
            "$ref": "#/components/schemas/NetPolicy"
          },
          "secrets": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Secret"
            }
          }
        },
        "additionalProperties": false
      },
      "Secret": {
        "type": "object",
        "required": [
          "name",
          "value_ref",
          "expose"
        ],
        "properties": {
          "expose": {
            "$ref": "#/components/schemas/SecretExpose"
          },
          "name": {
            "type": "string"
          },
          "value_ref": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "SecretExpose": {
        "type": "string",
        "enum": [
          "env",
          "file"
        ]
      },
      "Source": {
        "oneOf": [
          {
            "type": "object",
            "required": [
              "code",
              "kind"
            ],
            "properties": {
              "code": {
                "type": "string"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "inline"
                ]
              }
            }
          },
          {
            "type": "object",
            "required": [
              "path",
              "kind"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "wasm_file"
                ]
              },
              "path": {
                "type": "string"
              }
            }
          },
          {
            "type": "object",
            "required": [
              "text",
              "kind"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "wasm_wat"
                ]
              },
              "text": {
                "type": "string"
              }
            }
          },
          {
            "type": "object",
            "required": [
              "bytes",
              "kind"
            ],
            "properties": {
              "bytes": {
                "type": "string"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "wasm_bytes_base64"
                ]
              }
            }
          },
          {
            "type": "object",
            "required": [
              "sha256",
              "kind"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "module_ref"
                ]
              },
              "sha256": {
                "type": "string"
              }
            }
          }
        ]
      }
    }
  },
  "tags": [
    {
      "name": "v1",
      "description": "beatbox REST API"
    },
    {
      "name": "mcp",
      "description": "stateless MCP JSON-RPC endpoint"
    }
  ]
}
