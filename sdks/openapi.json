{
  "openapi": "3.1.0",
  "info": {
    "title": "beatbox API",
    "description": "HTTP and MCP server surfaces for beatbox.",
    "license": {
      "name": "Apache-2.0",
      "identifier": "Apache-2.0"
    },
    "version": "0.1.0"
  },
  "paths": {
    "/mcp": {
      "post": {
        "tags": [
          "mcp"
        ],
        "operationId": "mcp_post",
        "responses": {
          "200": {
            "description": "JSON-RPC response"
          },
          "202": {
            "description": "JSON-RPC notification accepted"
          },
          "403": {
            "description": "Origin not allowed"
          }
        }
      }
    },
    "/v1/browser/admit": {
      "post": {
        "tags": [
          "v1"
        ],
        "operationId": "browser_admit",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BrowserAdmissionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Browser sandbox admission decision",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BrowserAdmissionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Malformed JSON body",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/browser/profiles": {
      "get": {
        "tags": [
          "v1"
        ],
        "operationId": "browser_profiles",
        "responses": {
          "200": {
            "description": "Browser sandbox profile discovery contract",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BrowserProfilesResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/capabilities": {
      "get": {
        "tags": [
          "v1"
        ],
        "operationId": "capabilities",
        "responses": {
          "200": {
            "description": "Lane availability and host limits",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CapabilitiesResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/execute": {
      "post": {
        "tags": [
          "v1"
        ],
        "operationId": "execute",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExecuteRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "ExecutionResult",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ExecutionResult"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Protocol, source, policy, or sync-limit rejection",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/health": {
      "get": {
        "tags": [
          "v1"
        ],
        "operationId": "health",
        "responses": {
          "200": {
            "description": "Daemon health"
          }
        }
      }
    },
    "/v1/jobs": {
      "post": {
        "tags": [
          "v1"
        ],
        "operationId": "create_job",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExecuteRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Created asynchronous job",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateJobResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Idempotency key reused with a different payload",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Protocol, source, policy, or job-limit rejection",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Concurrency cap exhausted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/jobs/{id}": {
      "get": {
        "tags": [
          "v1"
        ],
        "operationId": "get_job",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Job id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "JobRecord",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobRecord"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "Unknown job",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "v1"
        ],
        "operationId": "cancel_job",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Job id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Canceled job (or already canceled)"
          },
          "401": {
            "description": "Missing or invalid bearer token"
          },
          "404": {
            "description": "Unknown job"
          },
          "409": {
            "description": "Job already finished and cannot be canceled"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BrowserAdmissionDecision": {
        "type": "string",
        "enum": [
          "accepted",
          "rejected"
        ]
      },
      "BrowserAdmissionRequest": {
        "type": "object",
        "required": [
          "requested_level",
          "actor",
          "sensitivity"
        ],
        "properties": {
          "actor": {
            "$ref": "#/components/schemas/BrowserSessionActor"
          },
          "allow_downgrade": {
            "type": "boolean"
          },
          "requested_level": {
            "$ref": "#/components/schemas/BrowserSandboxLevel"
          },
          "sensitivity": {
            "$ref": "#/components/schemas/BrowserSensitivity"
          },
          "task_label": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      },
      "BrowserAdmissionResponse": {
        "type": "object",
        "required": [
          "decision",
          "runnable_browser_sessions",
          "requested_level",
          "actor",
          "sensitivity",
          "downgrade_allowed",
          "reasons",
          "required_next_steps",
          "profiles_endpoint"
        ],
        "properties": {
          "actor": {
            "$ref": "#/components/schemas/BrowserSessionActor"
          },
          "decision": {
            "$ref": "#/components/schemas/BrowserAdmissionDecision"
          },
          "downgrade_allowed": {
            "type": "boolean"
          },
          "profiles_endpoint": {
            "type": "string"
          },
          "reasons": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "requested_level": {
            "$ref": "#/components/schemas/BrowserSandboxLevel"
          },
          "required_next_steps": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "runnable_browser_sessions": {
            "type": "boolean"
          },
          "selected_level": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/BrowserSandboxLevel"
              }
            ]
          },
          "sensitivity": {
            "$ref": "#/components/schemas/BrowserSensitivity"
          }
        },
        "additionalProperties": false
      },
      "BrowserIntegrationContract": {
        "type": "object",
        "required": [
          "status",
          "consumer",
          "endpoint",
          "admission_endpoint",
          "selection_field",
          "required_consumer_behavior"
        ],
        "properties": {
          "admission_endpoint": {
            "type": "string"
          },
          "consumer": {
            "type": "string"
          },
          "endpoint": {
            "type": "string"
          },
          "required_consumer_behavior": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "selection_field": {
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/BrowserSandboxAvailability"
          }
        },
        "additionalProperties": false
      },
      "BrowserProfilesResponse": {
        "type": "object",
        "required": [
          "version",
          "runnable_browser_sessions",
          "integration",
          "profiles"
        ],
        "properties": {
          "default_level": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/BrowserSandboxLevel"
              }
            ]
          },
          "integration": {
            "$ref": "#/components/schemas/BrowserIntegrationContract"
          },
          "profiles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BrowserSandboxProfile"
            }
          },
          "runnable_browser_sessions": {
            "type": "boolean"
          },
          "version": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "BrowserSandboxAvailability": {
        "type": "string",
        "enum": [
          "available",
          "planned",
          "unavailable"
        ]
      },
      "BrowserSandboxLevel": {
        "type": "string",
        "enum": [
          "instrumented_external",
          "ephemeral_profile",
          "network_suppressed",
          "sealed_state",
          "os_isolated",
          "remote_isolated"
        ]
      },
      "BrowserSandboxProfile": {
        "type": "object",
        "required": [
          "level",
          "availability",
          "summary",
          "isolation_boundary",
          "privacy_controls",
          "egress_controls",
          "credential_controls",
          "storage_controls",
          "encryption_claims",
          "non_goals",
          "downgrade_reasons"
        ],
        "properties": {
          "availability": {
            "$ref": "#/components/schemas/BrowserSandboxAvailability"
          },
          "credential_controls": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "downgrade_reasons": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "egress_controls": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "encryption_claims": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "isolation_boundary": {
            "type": "string"
          },
          "level": {
            "$ref": "#/components/schemas/BrowserSandboxLevel"
          },
          "non_goals": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "privacy_controls": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "storage_controls": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "summary": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "BrowserSensitivity": {
        "type": "string",
        "enum": [
          "public",
          "sensitive"
        ]
      },
      "BrowserSessionActor": {
        "type": "string",
        "enum": [
          "agent",
          "human"
        ]
      },
      "CapabilitiesResponse": {
        "type": "object",
        "required": [
          "version",
          "lanes",
          "limits",
          "engines",
          "browser_sandbox"
        ],
        "properties": {
          "browser_sandbox": {
            "$ref": "#/components/schemas/BrowserProfilesResponse"
          },
          "engines": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "propertyNames": {
              "type": "string"
            }
          },
          "lanes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CapabilityLane"
            }
          },
          "limits": {
            "$ref": "#/components/schemas/CapabilityLimits"
          },
          "version": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CapabilityLane": {
        "type": "object",
        "required": [
          "lane",
          "available",
          "substrate",
          "grade",
          "mechanisms"
        ],
        "properties": {
          "available": {
            "type": "boolean"
          },
          "grade": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "propertyNames": {
              "type": "string"
            }
          },
          "lane": {
            "$ref": "#/components/schemas/Lane"
          },
          "mechanisms": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "substrate": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "CapabilityLimits": {
        "type": "object",
        "required": [
          "sync_wall_ms",
          "job_wall_ms",
          "default_wall_ms",
          "default_memory_bytes",
          "default_output_bytes",
          "max_request_bytes",
          "max_memory_bytes",
          "max_output_bytes",
          "max_fuel",
          "max_concurrent_sync",
          "max_concurrent_jobs"
        ],
        "properties": {
          "default_memory_bytes": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "default_output_bytes": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "default_wall_ms": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "job_wall_ms": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "max_concurrent_jobs": {
            "type": "integer",
            "minimum": 0
          },
          "max_concurrent_sync": {
            "type": "integer",
            "minimum": 0
          },
          "max_fuel": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "max_memory_bytes": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "max_output_bytes": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "max_request_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "sync_wall_ms": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          }
        },
        "additionalProperties": false
      },
      "CreateJobResponse": {
        "type": "object",
        "required": [
          "job_id"
        ],
        "properties": {
          "job_id": {
            "type": "string"
          }
        }
      },
      "Determinism": {
        "oneOf": [
          {
            "type": "object",
            "required": [
              "kind"
            ],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "off"
                ]
              }
            }
          },
          {
            "type": "object",
            "required": [
              "seed",
              "epoch_ms",
              "kind"
            ],
            "properties": {
              "epoch_ms": {
                "type": "integer",
                "format": "int64",
                "minimum": 0
              },
              "kind": {
                "type": "string",
                "enum": [
                  "seeded"
                ]
              },
              "seed": {
                "type": "integer",
                "format": "int64",
                "minimum": 0
              }
            }
          }
        ]
      },
      "EffectiveIsolation": {
        "type": "object",
        "required": [
          "os",
          "mechanisms",
          "downgrades"
        ],
        "properties": {
          "downgrades": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "landlock_abi": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int32",
            "minimum": 0
          },
          "mechanisms": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "os": {
            "type": "string"
          }
        }
      },
      "EgressRecord": {
        "type": "object",
        "required": [
          "domain",
          "port",
          "bytes"
        ],
        "properties": {
          "bytes": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "domain": {
            "type": "string"
          },
          "port": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      },
      "ErrorBody": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ErrorBody"
          }
        }
      },
      "ExecuteRequest": {
        "type": "object",
        "required": [
          "lane",
          "source"
        ],
        "properties": {
          "entrypoint": {
            "type": [
              "string",
              "null"
            ]
          },
          "idempotency_key": {
            "type": [
              "string",
              "null"
            ]
          },
          "input": {},
          "lane": {
            "$ref": "#/components/schemas/Lane"
          },
          "policy": {
            "$ref": "#/components/schemas/Policy"
          },
          "source": {
            "$ref": "#/components/schemas/Source"
          },
          "stdin": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "ExecutionResult": {
        "type": "object",
        "required": [
          "status",
          "value",
          "stdout",
          "stdout_truncated",
          "stderr",
          "stderr_truncated",
          "metrics",
          "lane",
          "deterministic",
          "inputs_digest",
          "engine_version",
          "beatbox_version",
          "effective_isolation",
          "egress"
        ],
        "properties": {
          "beatbox_version": {
            "type": "string"
          },
          "deterministic": {
            "type": "boolean"
          },
          "effective_isolation": {
            "$ref": "#/components/schemas/EffectiveIsolation"
          },
          "egress": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/EgressRecord"
            }
          },
          "engine_version": {
            "type": "string"
          },
          "error": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ErrorBody"
              }
            ]
          },
          "exit_code": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int32"
          },
          "inputs_digest": {
            "type": "string"
          },
          "lane": {
            "$ref": "#/components/schemas/Lane"
          },
          "metrics": {
            "$ref": "#/components/schemas/Metrics"
          },
          "status": {
            "$ref": "#/components/schemas/ExecutionStatus"
          },
          "stderr": {
            "type": "string"
          },
          "stderr_truncated": {
            "type": "boolean"
          },
          "stdout": {
            "type": "string"
          },
          "stdout_truncated": {
            "type": "boolean"
          },
          "value": {}
        }
      },
      "ExecutionStatus": {
        "type": "string",
        "enum": [
          "ok",
          "error",
          "timeout",
          "oom",
          "killed",
          "denied"
        ]
      },
      "FsPolicy": {
        "type": "object",
        "properties": {
          "mounts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Mount"
            }
          },
          "workspace": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      },
      "JobRecord": {
        "type": "object",
        "required": [
          "job_id",
          "status",
          "request",
          "created_at",
          "updated_at"
        ],
        "properties": {
          "created_at": {
            "type": "string"
          },
          "error": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ErrorBody"
              }
            ]
          },
          "job_id": {
            "type": "string"
          },
          "request": {
            "$ref": "#/components/schemas/ExecuteRequest"
          },
          "result": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/ExecutionResult"
              }
            ]
          },
          "status": {
            "$ref": "#/components/schemas/JobStatus"
          },
          "updated_at": {
            "type": "string"
          }
        }
      },
      "JobStatus": {
        "type": "string",
        "enum": [
          "queued",
          "running",
          "succeeded",
          "failed",
          "canceled"
        ]
      },
      "Lane": {
        "type": "string",
        "enum": [
          "wasm",
